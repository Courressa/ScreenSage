# App PORT is optional locally (defaults to 3000). Render sets PORT automatically.
# PORT=3000

VITE_FORMSPREE_ID=string

# Frontend API base. Local Vite → local Express.
# On Render (frontend + API same host) you can omit this; production builds default to /api/v1.
# If set, must include /api/v1:
# VITE_API_URL=https://screensageai.com/api/v1
VITE_API_URL=http://localhost:3000/api/v1

# Comma-separated browser origins for CORS. Same-origin Render traffic is fine without listing Render.
# Include local Vite when calling a remote API from your machine.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

MONGODB_URI=string
JWT_SECRET=string
CLOUDINARY_CLOUD_NAME=string
CLOUDINARY_API_KEY=number
CLOUDINARY_API_SECRET=string

# Mail (Resend recommended)
# Prefer HTTPS API on Render — SMTP to Resend often hits "Connection timeout".
# Option A (best on Render): API key
RESEND_API_KEY=re_xxxxxxxxx
EMAIL_FROM=ScreenSage <orders@your-verified-domain.com>

# Option B: SMTP (works locally; may time out on some hosts)
# If SMTP_HOST is smtp.resend.com and SMTP_PASS starts with re_,
# the server automatically uses the Resend HTTPS API instead.
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxx

# ====================== PayPal ======================
# Sandbox: https://developer.paypal.com/dashboard/applications/sandbox
# Frontend only needs the public Client ID (Vite exposes VITE_* vars).
VITE_PAYPAL_CLIENT_ID=your-sandbox-client-id

# Server (never expose secret to the browser)
PAYPAL_CLIENT_ID=your-sandbox-client-id
PAYPAL_CLIENT_SECRET=your-sandbox-secret
# sandbox | live
PAYPAL_MODE=sandbox

# ====================== Stripe ======================
# Dashboard: https://dashboard.stripe.com/test/apikeys
# Frontend (optional flag to show the button; use publishable key)
VITE_STRIPE_KEY=pk_test_...
# Server only — never expose sk_ to the browser
STRIPE_SECRET_KEY=sk_test_...
# Where Stripe sends the browser after pay / cancel (no trailing slash)
# Local Vite:
FRONTEND_URL=http://localhost:5173
# Production (Render env — no trailing slash):
# FRONTEND_URL=https://screensageai.com
